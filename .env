# Copy to .env and fill in real values. Never commit .env.

# Flask session signing secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=fb20a755fac3ae9546ede520063b16c591632008aaff69d8d3cbbc0d055f309e

# HuggingFace API key — create a Read token at https://huggingface.co/settings/tokens
# Select: Fine-grained → Read access (Write is NOT needed)
HF_API_KEY=hf_...

# (Optional) Override the default HF inference model. Default: Qwen/Qwen2.5-7B-Instruct
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Gemma local model settings.
# GPU offload layers: 0 = CPU only (safe default); -1 = full GPU offload
#   (GPU requires: pip install llama-cpp-python --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu124)
GEMMA_GPU_LAYERS=0

# Number of CPU threads llama-cpp uses for inference.
# 2 = keeps CPU under ~25% on 8-core machines (recommended for demo)
# 4 = faster but CPU may hit 50-60%
# 6+ = fastest but CPU will spike near 100%
GEMMA_N_THREADS=2
